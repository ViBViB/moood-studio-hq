{
    "functions": {
        "api/intake.js": { "maxDuration": 60 },
        "api/proposal.js": { "maxDuration": 60 }
    },
    "redirects": [
        {
            "source": "/proposals/preoptima",
            "destination": "/proposals/sent/preoptima/",
            "permanent": false
        },
        {
            "source": "/proposals/preoptima/",
            "destination": "/proposals/sent/preoptima/",
            "permanent": false
        },
        {
            "source": "/club-pilates-remix",
            "destination": "/club-pilates-remix/",
            "permanent": false
        },
        {
            "source": "/treinos",
            "destination": "/treinos/",
            "permanent": false
        },
        {
            "source": "/anthros/catalog",
            "destination": "/anthros/catalog/",
            "permanent": false
        }
    ],
    "rewrites": [
        { "source": "/api/generate-proposal", "destination": "/api/proposal?mode=generate" },
        { "source": "/api/preview-proposal", "destination": "/api/proposal?mode=preview" },
        { "source": "/api/approve", "destination": "/api/proposal?mode=approve" },
        { "source": "/api/magic", "destination": "/api/proposal?mode=extract" },
        { "source": "/api/proposal", "destination": "/api/proposal" },
        
        { "source": "/api/client-intake", "destination": "/api/intake?mode=submit" },
        { "source": "/api/client-intake-approve", "destination": "/api/intake?mode=approve" },
        { "source": "/api/intake", "destination": "/api/intake?mode=strategic" },

        { "source": "/api/book", "destination": "/api/leads?mode=book" },
        { "source": "/api/quote", "destination": "/api/leads?mode=quote" },

        { "source": "/api/validate-code", "destination": "/api/utils?mode=validate-code" },
        { "source": "/api/sitemap-feedback", "destination": "/api/utils?mode=feedback" },

        { "source": "/client-intake", "destination": "/proposals/_templates/web-design/client-intake.html" },
        { "source": "/admin/generate", "destination": "/proposals/generator/index.html" },
        { "source": "/narrative-review", "destination": "/proposals/narrative-review/index.html" },
        { "source": "/p/:id", "destination": "/api/proposal?id=:id" },
        { "source": "/treinos/", "destination": "https://dani-treinos.vercel.app/" },
        { "source": "/treinos/:path*", "destination": "https://dani-treinos.vercel.app/:path*" },
        { "source": "/club-pilates-remix/", "destination": "https://club-pilates-remix.vercel.app/" },
        { "source": "/club-pilates-remix/:path*", "destination": "https://club-pilates-remix.vercel.app/:path*" },

        { "source": "/anthros/catalog", "destination": "https://anthros-catalog.vercel.app/" },
        { "source": "/anthros/catalog/", "destination": "https://anthros-catalog.vercel.app/" },
        { "source": "/anthros/catalog/:path*", "destination": "https://anthros-catalog.vercel.app/:path*" }
    ]
}