                  "fill": "#000000ff",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Strategic Resilience",
                  "fontFamily": "Helvetica Now Display",
                  "fontSize": 24,
                  "fontWeight": "300"
                },
                {
                  "type": "text",
                  "id": "heAu6",
                  "fill": "#000000ff",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We recognize the internal discussions regarding the company name. This system is built to be flexible, ensuring visual stability regardless of future naming decisions.",
