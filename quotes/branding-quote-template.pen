                {
                  "type": "text",
                  "id": "AzZ2I",
                  "fill": "#000000ff",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "You’ve identified that the current logo feels generic and the colors are restrictive.",
                  "fontFamily": "Helvetica Now Display",
                  "fontSize": 12
                }
              ]
            },
            {
              "type": "group",
              "id": "T6k6I",
