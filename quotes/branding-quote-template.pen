                  "fill": "#000000ff",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The Opportunity",
                  "fontFamily": "Helvetica Now Display",
                  "fontSize": 24,
                  "fontWeight": "300"
                },
                {
                  "type": "text",
                  "id": "VzpPT",
                  "fill": "#000000ff",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "To replace the \"stock\" feel with a bespoke identity that reflects your status as an innovative startup at the intersection of climate tech and digital planning.",
                  "lineHeight": 1.5,
                  "fontFamily": "Helvetica Now Display",
                  "fontSize": 12
                }
              ]
            },
